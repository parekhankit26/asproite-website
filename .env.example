# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# Sets the initial admin password on first boot (only used if data/admin-auth.json
# doesn't exist yet). If omitted, a random one-time password is generated and
# printed to the server log on first start — log in with it and change it
# immediately from Admin -> Security.
ADMIN_PASSWORD=

# GitHub personal access token with "repo" scope. Lets Admin -> Save push
# public/sitedata.json straight to GitHub so the live site updates automatically.
# Leave blank to disable GitHub sync (saves still write to the local file).
GITHUB_TOKEN=

# Anthropic API key that powers the "Ask Asproite AI" chat widget for every
# visitor. Leave blank and the widget falls back to showing contact details.
ANTHROPIC_API_KEY=

PORT=3000
